# ──────────────────────────────────────────────────────────────────────────────
# LM Studio AI Agent Lab — 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 수정하세요: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── LM Studio (로컬 LLM 백엔드, 필수) ─────────────────────────────────────────
# LM Studio 실행 후 좌측 상단 "Local Server" 탭에서 서버를 시작하세요.
# 기본 포트: 1234  /  Docker 컨테이너에서는 host.docker.internal 사용
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
# LM Studio 에서 현재 로드한 모델명 (모델 드롭다운에서 확인)
LM_STUDIO_MODEL=local-model

# ── RAG 설정 ──────────────────────────────────────────────────────────────────
VECTOR_COLLECTION=finance_agent_lab
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=1024
CHUNK_SIZE=900
CHUNK_OVERLAP=150
DEFAULT_TOP_K=6
DEFAULT_ORCHESTRATOR=native

# ── 인증/사용자 저장소 ─────────────────────────────────────────────────────────
AUTH_SECRET=change-me-in-production
AUTH_TOKEN_TTL_SECONDS=86400
USER_STORE_MODE=auto
USER_VECTOR_COLLECTION=agent_users

# ── Qdrant 벡터DB (docker compose 로 함께 실행됨) ─────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_USER_COLLECTION=agent_users

# ── MariaDB (USER_STORE_MODE=mariadb 사용 시) ─────────────────────────────────
MARIADB_ROOT_PASSWORD=rootpass
MARIADB_DATABASE=agentdb
MARIADB_USER=agent
MARIADB_PASSWORD=agentpass
MARIADB_HOST=mariadb
MARIADB_PORT=3306
# MARIADB_URL=mysql+pymysql://agent:agentpass@mariadb:3306/agentdb?charset=utf8mb4

# ── LangSmith 추적 (선택) ──────────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finance-agent-lab

# ── OpenAI 호환 클라우드 API (선택, LM Studio 가 우선) ────────────────────────
# OPENAI_API_KEY 를 설정하면 LM Studio 대신 OpenAI API 를 사용합니다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_VISION_MODEL=gpt-4o-mini

# ── 3rd-party API (실무형 확장, 모두 선택) ────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
OCR_SPACE_API_KEY=
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_TOPIC=general
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
WEB_SEARCH_FALLBACK_THRESHOLD=0.34
