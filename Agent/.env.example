# OpenAI를 사용하지 않으면 비워도 동작(검색 기반 요약 답변)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_VISION_MODEL=gpt-4o-mini

# RAG 설정
VECTOR_COLLECTION=finance_agent_lab
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=1024
CHUNK_SIZE=900
CHUNK_OVERLAP=150
DEFAULT_TOP_K=6
DEFAULT_ORCHESTRATOR=native

# 인증/사용자 저장소
AUTH_SECRET=change-me-in-production
AUTH_TOKEN_TTL_SECONDS=86400
USER_STORE_MODE=auto
USER_VECTOR_COLLECTION=agent_users

# MariaDB (USER_STORE_MODE=auto/mariadb 에서 사용)
MARIADB_ROOT_PASSWORD=rootpass
MARIADB_DATABASE=agentdb
MARIADB_USER=agent
MARIADB_PASSWORD=agentpass
MARIADB_HOST=mariadb
MARIADB_PORT=3306
# MARIADB_URL=mysql+pymysql://agent:agentpass@mariadb:3306/agentdb?charset=utf8mb4

# LangSmith 추적
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finance-agent-lab

# 3rd-party API (실무형 확장)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
OCR_SPACE_API_KEY=
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_TOPIC=general
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
WEB_SEARCH_FALLBACK_THRESHOLD=0.34
